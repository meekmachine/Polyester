{
  "name": "@lovelace_lol/polyester",
  "version": "0.0.0",
  "description": "ClojureScript worker-backed character runtime agencies for Character Loom",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cljs": {
      "types": "./types/cljs.d.ts",
      "import": "./dist/cljs/index.js"
    },
    "./cljs-worker": {
      "default": "./dist/cljs-worker/worker.js"
    }
  },
  "files": [
    "dist",
    "types",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && npm run build:cljs && node scripts/copy-snippets.mjs",
    "build:cljs": "shadow-cljs release npm worker",
    "dev": "tsup --watch",
    "dev:cljs": "shadow-cljs watch npm worker",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cljs": "npm run build:cljs && node scripts/check-cljs-mixer-boundary.mjs && node scripts/smoke-cljs-blink.mjs && node scripts/smoke-cljs-azure-parity.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@lovelace_lol/loom3": "^1.0.38",
    "effect": "^3.19.14",
    "most-subject": "^6.0.0",
    "rxjs": "^7.8.2",
    "xstate": "^5.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.27.4",
    "shadow-cljs": "^3.4.11",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "three": ">=0.170.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "keywords": [
    "animation",
    "avatar",
    "character-animation",
    "conversation",
    "gaze",
    "lip-sync",
    "prosody",
    "tts",
    "xstate"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meekmachine/Polyester.git"
  },
  "bugs": {
    "url": "https://github.com/meekmachine/Polyester/issues"
  },
  "homepage": "https://github.com/meekmachine/Polyester#readme",
  "author": "Jonathan",
  "license": "MIT",
  "packageManager": "npm@10.9.2"
}
