{:source-paths ["src-cljs"]
 :builds
 {:npm
  {:target :esm
   :output-dir "dist/cljs"
   :modules
   {:index
    {:exports
     {createBlinkAgency latticework.npm/create-blink-agency
      createAnimationAgency latticework.npm/create-animation-agency
      createGazeAgency latticework.npm/create-gaze-agency
      createHairAgency latticework.npm/create-hair-agency
      createLipSyncAgency latticework.npm/create-lipsync-agency
      createProsodicAgency latticework.npm/create-prosodic-agency
      createVocalAgency latticework.npm/create-vocal-agency
      createAnimationWorkerClient latticework.npm/create-animation-worker-client
      createBlinkWorkerClient latticework.npm/create-blink-worker-client
      createGazeWorkerClient latticework.npm/create-gaze-worker-client
      createHairWorkerClient latticework.npm/create-hair-worker-client
      createLipSyncWorkerClient latticework.npm/create-lipsync-worker-client
      createProsodicWorkerClient latticework.npm/create-prosodic-worker-client
      createVocalWorkerClient latticework.npm/create-vocal-worker-client
      createAgencyWorkerClient latticework.npm/create-agency-worker-client
      installLatticework latticework.npm/install-latticework}}}}

  :worker
  {:target :browser
   :output-dir "dist/cljs-worker"
   :asset-path "/cljs-worker"
   :modules
   {:worker
    {:init-fn latticework.worker/init
     :web-worker true}}}}}
